    "minify-next-ui-colors": "tsx scripts/minify-next-ui-colors.ts",
    "lint": "nuxt prepare && eslint .",
    "lint:fix": "nuxt prepare && eslint . --fix",
    "format": "prettier --write .",
    "find:nodeNative": "find node_modules -name \"*.node\"",
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "vitest --environment nuxt",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui"
